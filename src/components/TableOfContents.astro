---
interface Props {
  headings: Array<{ depth: number; slug: string; text: string }>;
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth <= 3);
---

{
  filteredHeadings.length > 0 && (
    <nav class="toc" aria-label="Table of contents">
      <h4 class="text-xs font-semibold uppercase tracking-wider text-text-tertiary mb-3">
        On this page
      </h4>
      <ul class="space-y-1.5">
        {filteredHeadings.map((heading) => (
          <li
            class:list={[
              "toc-item",
              heading.depth === 2 && "pl-0",
              heading.depth === 3 && "pl-3",
            ]}
          >
            <a
              href={`#${heading.slug}`}
              class="block text-sm text-text-tertiary hover:text-text-primary transition-colors py-0.5 border-l-2 border-transparent hover:border-accent"
              data-heading={heading.slug}
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}

<script is:inline>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        const link = document.querySelector(
          `a[data-heading="${entry.target.id}"]`
        );
        if (entry.isIntersecting && link) {
          document.querySelectorAll(".toc a").forEach((a) => {
            a.classList.remove("text-accent-light", "border-accent");
            a.classList.add("text-text-tertiary", "border-transparent");
          });
          link.classList.remove("text-text-tertiary", "border-transparent");
          link.classList.add("text-accent-light", "border-accent");
        }
      });
    },
    { rootMargin: "-80px 0px -80% 0px" }
  );

  document.querySelectorAll("h2[id], h3[id]").forEach((heading) => {
    observer.observe(heading);
  });
</script>
