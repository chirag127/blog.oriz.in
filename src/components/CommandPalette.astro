<div class="fixed bottom-6 right-6 z-[150]">
  <button
    id="command-palette-trigger"
    class="w-10 h-10 rounded-full glass-card flex items-center justify-center text-text-tertiary hover:text-text-primary transition-all hover:shadow-card"
    aria-label="Command palette"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
    </svg>
  </button>
</div>

<script is:inline>
  document.getElementById("command-palette-trigger")?.addEventListener("click", () => {
    document.getElementById("search-modal")?.classList.remove("hidden");
    document.getElementById("search-input")?.focus();
  });
</script>
