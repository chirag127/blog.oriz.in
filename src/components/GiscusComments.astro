---
// Removed unused import: SITE_CONFIG is no longer referenced directly; values are passed via props
---

<div class="glass-card p-6">
  <h3 class="text-lg font-semibold mb-6">Comments</h3>
  <div id="giscus-container">
    <script
      src="https://giscus.app/client.js"
      data-repo="orizin1/blog-comments"
      data-repo-id="R_kgDOMsK34w"
      data-category="Announcements"
      data-category-id="DIC_kwDOMsK3484Cg6h3"
      data-mapping="pathname"
      data-strict="0"
      data-reactions-enabled="1"
      data-emit-metadata="0"
      data-input-position="bottom"
      data-theme="dark"
      data-lang="en"
      data-loading="lazy"
      crossorigin="anonymous"
      is:inline
      async
    />
  </div>
</div>

<script is:inline>
  if (typeof window !== "undefined") {
    const updateGiscusTheme = () => {
      const iframe = document.querySelector("iframe.giscus-frame");
      if (!iframe) return;
      const isDark = document.documentElement.classList.contains("dark");
      iframe.contentWindow?.postMessage(
        {
          giscus: {
            setConfig: {
              theme: isDark ? "dark" : "light",
            },
          },
        },
        "https://giscus.app"
      );
    };

    const observer = new MutationObserver(updateGiscusTheme);
    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["class"],
    });
  }
</script>