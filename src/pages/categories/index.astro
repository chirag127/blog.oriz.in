---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const categoryMap = new Map<string, number>();

allPosts.forEach((post) => {
  categoryMap.set(
    post.data.category,
    (categoryMap.get(post.data.category) || 0) + 1
  );
});

const sortedCategories = [...categoryMap.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="Categories">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
    <div class="mb-10 animate-fade-in">
      <h1 class="text-4xl font-bold tracking-tight mb-3">Categories</h1>
      <p class="text-lg text-text-secondary">
        {sortedCategories.length} categor{sortedCategories.length !== 1 ? "ies" : "y"}
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {sortedCategories.map(([category, count]) => (
        <a
          href={`/categories/${category.toLowerCase().replace(/[\s\/]+/g, "-")}`}
          class="group glass-card p-6 hover:-translate-y-1 transition-all hover:shadow-card"
        >
          <h3 class="text-lg font-semibold text-text-primary group-hover:text-accent-light transition-colors">
            {category}
          </h3>
          <p class="text-sm text-text-tertiary mt-1">
            {count} post{count !== 1 ? "s" : ""}
          </p>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
