---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <section class="max-w-2xl mx-auto px-4 sm:px-6 py-32 text-center">
    <div class="animate-fade-in">
      <p class="text-8xl font-bold gradient-text mb-4">404</p>
      <h1 class="text-2xl font-bold mb-3">Page not found</h1>
      <p class="text-text-secondary mb-8">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/" class="btn-primary">
          Go home
        </a>
        <a href="/blog" class="btn-ghost border border-border">
          Browse blog
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
