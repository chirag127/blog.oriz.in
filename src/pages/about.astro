---

<BaseLayout title="About" description="Learn more about Chirag Singhal — Software Engineer, full-stack developer, and open-source enthusiast.">
  <section class="max-w-4xl mx-auto px-4 sm:px-6 pt-20 pb-16">
    <div class="animate-fade-in">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-accent/10 text-accent-light text-sm mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
        Software Engineer
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight leading-[1.1] mb-4">
        Hi, I'm <span class="gradient-text">Chirag Singhal</span>
      </h1>

      <p class="text-lg text-text-secondary leading-relaxed max-w-2xl">
        Software Engineer at TCS (Jun 2025 – Present). Previously Full Stack Developer at QRsay.com. B.Tech CSE, AKTU — College Topper (Rank 1), CGPA 8.81. JEE Advanced 2020: AIR 11870 (Top 1%).
      </p>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 sm:px-6 pb-16 animate-slide-up">
    <div class="glass-card p-8">
      <h2 class="text-2xl font-bold tracking-tight mb-6">Skills</h2>
      <div class="flex flex-wrap gap-2">
        {skills.map((skill) => (
          <span class="px-3 py-1.5 text-sm rounded-lg bg-bg-tertiary text-text-secondary border border-border">
            {skill}
          </span>
        ))}
      </div>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 sm:px-6 pb-16 animate-slide-up" style="animation-delay: 100ms;">
    <div class="glass-card p-8">
      <h2 class="text-2xl font-bold tracking-tight mb-6">Projects</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {projects.map((project) => (
          <a
            href={project.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group block p-5 rounded-xl bg-bg-secondary border border-border hover:border-border-hover transition-all duration-300 hover:-translate-y-0.5"
          >
            <h3 class="text-lg font-semibold text-text-primary group-hover:text-accent-light transition-colors mb-1">
              {project.name}
            </h3>
            <p class="text-sm text-text-secondary">{project.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 sm:px-6 pb-16 animate-slide-up" style="animation-delay: 200ms;">
    <div class="glass-card gradient-border p-8">
      <h2 class="text-2xl font-bold tracking-tight mb-6">Connect</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        {socialLinks.map((link) => (
          <a
            href={link.href}
            target={link.href.startsWith("mailto:") ? undefined : "_blank"}
            rel={link.href.startsWith("mailto:") ? undefined : "noopener noreferrer"}
            class="group flex items-center gap-3 p-3 rounded-xl bg-bg-secondary border border-border hover:border-border-hover transition-all duration-300"
          >
            <span class="flex items-center justify-center w-9 h-9 rounded-lg bg-bg-tertiary text-text-tertiary group-hover:text-accent-light group-hover:bg-accent/10 transition-colors">
              <svg class="w-4.5 h-4.5" viewBox="0 0 24 24" fill="currentColor" set:html={socialIcons[link.icon]} />
            </span>
            <span class="text-sm font-medium text-text-secondary group-hover:text-text-primary transition-colors">
              {link.name}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
