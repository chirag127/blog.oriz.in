---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE_CONFIG } from "../config";

const skills = [
  "Python", "TypeScript", "React", "Astro", "FastAPI", "Node.js",
  "Django", "Kafka", "Redis", "Docker", "Kubernetes", "Terraform",
  "AWS", "Cloudflare Workers", "LangChain", "RAG Pipelines",
  "Firebase", "Supabase", "MongoDB", "Turso",
];

const projects = [
  {
    name: "Oriz",
    url: "https://oriz.in",
    description: "1000+ Free Online Tools Platform",
  },
  {
    name: "NexusAI",
    url: "https://github.com/chirag127/NexusAI",
    description: "Multi-Agent RAG Platform",
  },
  {
    name: "TubeDigest",
    url: "https://github.com/chirag127/TubeDigest",
    description: "Multimodal Sponsor Detection",
  },
  {
    name: "Olivia",
    url: "https://github.com/chirag127/Olivia",
    description: "Edge AI Voice Assistant",
  },
];

const socialLinks = [
  { name: "GitHub", href: `https://github.com/${SITE_CONFIG.social.github}`, icon: "github" },
  { name: "LinkedIn", href: `https://linkedin.com/in/${SITE_CONFIG.social.linkedin}`, icon: "linkedin" },
  { name: "Email", href: `mailto:${SITE_CONFIG.social.email}`, icon: "email" },
  { name: "Bluesky", href: `https://bsky.app/profile/${SITE_CONFIG.social.bluesky}`, icon: "bluesky" },
  { name: "Mastodon", href: `https://mastodon.social/${SITE_CONFIG.social.mastodon}`, icon: "mastodon" },
  { name: "LeetCode", href: `https://leetcode.com/${SITE_CONFIG.social.leetcode}`, icon: "leetcode" },
];

