# ============================================
# Environment Variables for Chirag's Blog
# ============================================
# Copy this file to .env and fill in values
# For Cloudflare Pages, set these in:
#   Dashboard → Workers & Pages → blog-hunter → Settings → Environment variables
# ============================================

# --- Site Config ---
PUBLIC_SITE_URL=https://blog.oriz.in

# Cloudflare Web Analytics (ZERO JS impact - perfect 100 Lighthouse)
# Get from: Cloudflare Dashboard → Web Analytics → Add a site
PUBLIC_CF_BEACON=

# ============================================
# CLOUDFLARE DEPLOYMENT SECRETS (GitHub)
# ============================================
# These go in GitHub repo secrets, NOT here:
#   CLOUDFLARE_ACCOUNT_ID  → dash.cloudflare.com → URL or Overview sidebar
#   CLOUDFLARE_API_TOKEN   → dash.cloudflare.com/profile/api-tokens
# ============================================
